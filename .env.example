# Copy to .env and fill in. NEVER commit your real .env.

# Phoenix secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# Database connection
DATABASE_URL=ecto://postgres:postgres@localhost:5432/financial_glance_dev

# Default currency for this instance (ISO 4217). OSS default: USD. Set to VND, EUR, etc.
DEFAULT_CURRENCY=USD

# API host/port
PORT=4000
